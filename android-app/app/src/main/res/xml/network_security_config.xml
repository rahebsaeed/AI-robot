<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Development/PFE LAN mode. Replace ws:// with pinned wss:// for deployment. -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
